  m_GameObject: {fileID: 1576598634}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c8b890b226d85054e9769202f3100704, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  apiKey: 
  dialoguePrefab: {fileID: 1955208573117639016, guid: ada96a3f2b999674ba03a458e3e26fb5, type: 3}
  Dialogues: []
  Characters:
  - {fileID: 2059035740}
  - {fileID: 1842401093}
  - {fileID: 142131068}
  dialogueEntries: []
  events: []
  mainGameSystemPrompt: We are playing a game based on the stage play 'No Exit' by
    Jean-Paul Sartre, which delves into existential themes and the human condition.
  characterSetupSystemPrompt: ' You are a script writer creating a character for
    the play.'
  characterSetupUserPrompt: "Generate a unique character description for a character
    in this game/play.\nPlease include the following details:\n- Name\n- Age\n- Place
    of Birth\n- Occupation\n- Cause of Death\n\nEnsure the character\u2019s background
    and personality reflect the dark, existential atmosphere of 'No Exit' while remaining
    original and fitting within the narrative of our game. The name of the character
    you are creating is: "
  characterNameUserPrompt: "Generate a unique and creative character name. Your response
    must consist solely of two words\u2014a first name and a last name\u2014separated
    by a single space. Do not include any additional text, punctuation, or explanation."
  characterDialogueSystemPrompt: "You are an actor portraying a character in the
    stage play *No Exit* by Jean-Paul Sartre. You must remain entirely in character
    for every response. Do not offer extra explanations or break character; keep
    your answers brief and strictly from your character\u2019s perspective.\n\nBelow
    is your character description:\n"
  characterDialogueSystemPromptEnding: "Context:  \r\nWhen the user input is appended
    after this message, respond solely in character as the described persona in your
    character description. Do not include any out-of-character commentary, meta descriptions,
    or notes about your acting\u2014simply reply as the character you are playing
    would.\r\n"
  characterDialogueUserPromptEnding: 'Context:

    Take into account the information
    you are aware about the user when replying:'
  characterDialogueUserPromptEnding2: 'Rules:

    When user details or any known
    information are provided in the context or appended by the user, do not ask for
    or repeat that information. Simply acknowledge and incorporate it naturally into
    your in-character responses. Give brief replies.'
  infoExtractionSystemPrompt: "You are a personal information extractor for the character
    you are portraying. You are provided with the full character description (above)
    and a user message below. Your task is to identify and output, on a single line,
    any personal information (such as name, age, place of birth, occupation, cause
    of death) that is either explicitly mentioned or can be reasonably inferred from
    the user message, but only if it exactly matches the corresponding detail in
    the character description.\r\n\r\nInstructions:\r\n- Compare the user message
    with the character description.\r\n\r- If a detail mentioned in the user message
    contradicts or does not  match the character description, ignore that detail.\r\n-
    Only output the details that exactly match the character description. Do not
    output any labels or the word 'none' for individual details.\r\n- If none of
    the details from the character description are explicitly mentioned or reasonably
    inferred in the user message, output exactly: none\r\n\r\nDo not include any
    additional text, greetings, or commentary.\r\n"
  systemPrompts:
  - 
  - 
  - 
  temp: 0.5
  charaterTemp: 1
  modelDialogue: gpt-3.5-turbo
  modelInfo: ft:gpt-3.5-turbo-1106:ck80:training1:B8ihcA3A
  adressingSystemPrompt: "You are an assistant that determines if the user is addressing
    either of two characters in a play. You will be provided with details about two
    known characters (in the system prompt) and a user message (in the user prompt).
    Your task is to check if the user message explicitly refers to any known aspects
    of either character.\r\n\r\n- If the user message addresses any known aspect
    of character 1, reply with \"1\".\r\n- If it addresses any known aspect of character
    2, reply with \"2\".\r\n- If the user message does not address any character
    details, reply with \"0\".\n- If the user message address both character details,
    reply with \"0\".\r\n\r\nDo not include any additional text, commentary, or explanations.\r"
